# Ignore everything by default
*

# But include these files and directories
!.gitignore
!agents/
!skills/
!rules/
!CLAUDE.md
!README.md
!RTK.md
!hooks/
!output-styles/
!plugins/
!docs/
!settings.json

# Include contents of these directories
!agents/**
!skills/**
!skills/**/*
!rules/**
!hooks/**
!output-styles/**
# plugins: only config files, exclude cache/marketplaces/counts
plugins/cache/**
plugins/marketplaces/**
plugins/install-counts-cache.json
!docs/**

# Exclude all backups
backups/**

# Exclude all .DS_Store files
**/.DS_Store
.DS_Store
